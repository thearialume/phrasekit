{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "build.ts"]
}
